{
  "name": "gozd",
  "version": "0.0.0",
  "private": true,
  "description": "AI Agent Orchestrator",
  "type": "module",
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "dev:prod": "rm -rf \"$TMPDIR/gozd-stable-launch\" \"$TMPDIR/gozd-stable.sock\" && env -u GOZD_SOCKET_PATH apps/electron/out/mac-arm64/Gozd.app/Contents/Resources/app/bin/gozd",
    "build": "pnpm -r build",
    "bootstrap": "pnpm --filter @gozd/electron build:app && open apps/electron/out/mac-arm64/Gozd.app",
    "format": "oxfmt .",
    "lint": "oxlint --type-aware",
    "fix": "oxfmt '!apps/**' '!packages/**'",
    "lint:all": "pnpm -r --include-workspace-root --if-present --no-bail --aggregate-output --reporter=append-only lint",
    "fix:all": "pnpm -r --include-workspace-root --if-present --no-bail --aggregate-output --reporter=append-only fix",
    "test": "bun test scripts",
    "test:all": "pnpm -r --include-workspace-root --if-present --no-bail --aggregate-output --reporter=append-only test",
    "typecheck:all": "pnpm -r --include-workspace-root --if-present typecheck",
    "knip": "knip",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "concurrently": "10.0.3",
    "knip": "6.24.0",
    "lefthook": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:"
  }
}
