#!/usr/bin/env bash

# gozd shell wrapper — Phase 5 で旧 apps/cli/bin/gozd と置き換える Swift CLI 用版。
#
# .app 内配置（Phase 4 build で確定）:
#   gozd.app/Contents/Resources/app/bin/gozd        ← このスクリプト
#   gozd.app/Contents/Resources/app/bin/gozd-cli    ← Swift CLI バイナリ
#   gozd.app/Contents/MacOS/Gozd                    ← Swift メインアプリバイナリ
#
# 動作:
#   - hook サブコマンド or -- で始まる引数: アプリ起動チェックなしで CLI を直接呼ぶ
#   - open（デフォルト）: ソケット稼働中なら warm start、なければ cold start で
#     CLI に launch request を書かせてから .app を `open` で起動する

set -euo pipefail

# シンボリックリンクを解決して実体のディレクトリを取得
SOURCE="$0"
while [[ -L "${SOURCE}" ]]; do
  DIR="$(cd "$(dirname "${SOURCE}")" && pwd)"
  SOURCE="$(readlink "${SOURCE}")"
  [[ "${SOURCE}" != /* ]] && SOURCE="${DIR}/${SOURCE}"
done
SCRIPT_DIR="$(cd "$(dirname "${SOURCE}")" && pwd)"

CLI="${SCRIPT_DIR}/gozd-cli"
APP_RESOURCES="${SCRIPT_DIR}/.."
APP_CONTENTS="${APP_RESOURCES}/../.."
APP_BUNDLE="${APP_CONTENTS}/.."

TMPDIR_NORMALIZED="${TMPDIR:-/tmp}"
SOCKET_PATH="${GOZD_SOCKET_PATH:-${TMPDIR_NORMALIZED%/}/gozd-swift-stable.sock}"

is_app_running() {
  [[ -S "${SOCKET_PATH}" ]] || return 1
  # ソケットファイルがあっても実際に接続できるか確認（残骸検出）
  if ! echo "" | nc -U "${SOCKET_PATH}" 2>/dev/null; then
    rm -f "${SOCKET_PATH}"
    return 1
  fi
  return 0
}

# hook / フラグ系はアプリ起動を要求しない
should_launch_app() {
  is_app_running && return 1
  [[ "${1:-}" == "hook" || "${1:-}" == -* ]] && return 1
  return 0
}

if should_launch_app "$@"; then
  # cold start: CLI に launch request ファイルを書かせてからアプリを起動
  GOZD_COLD_START=1 GOZD_SOCKET_PATH="${SOCKET_PATH}" "${CLI}" "$@" || exit $?
  open "${APP_BUNDLE}"
  exit $?
fi

# warm start: ソケット経由で送信（exec して exit code を継承）
exec env GOZD_SOCKET_PATH="${SOCKET_PATH}" "${CLI}" "$@"
