{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "skipLibCheck": true,
    "rootDir": "src",
    "outDir": "dist",
    "types": ["vite/client", "@orkis/preload"]
  },
  "include": ["src"]
}
