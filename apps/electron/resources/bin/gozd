#!/usr/bin/env bash

# gozd shell wrapper。
#
# .app 内配置:
#   Gozd.app/Contents/Resources/app/bin/gozd        ← このスクリプト
#   Gozd.app/Contents/Resources/app/bin/gozd-cli    ← TS CLI の shim
#   Gozd.app/Contents/Resources/app/channel         ← channel marker（buildApp.ts が焼き込む）
#   Gozd.app/Contents/MacOS/Gozd                    ← Electron メインバイナリ
#
# 動作:
#   - hook サブコマンド or -- で始まる引数: アプリ起動チェックなしで CLI を直接呼ぶ
#   - sync-app サブコマンド: ~/Applications/Gozd.app へ自己同期して終了する（stable のみ）。
#     mise の postinstall から呼ばれる更新伝播の主経路
#   - open（デフォルト）: ソケット稼働中なら warm start、なければ cold start で
#     CLI に launch request を書かせてから .app を `open` で起動する
#
# channel marker:
#   socket 名（gozd-<channel>.sock）と cold start の分岐に使う。stable（mise 配布）だけ
#   cold start 時に ~/Applications/Gozd.app へ自己同期してから固定パス側を open する。
#   marker が無い場合（リポジトリ checkout 内の wrapper）は従来どおり stable socket 宛て・
#   同期なし（アプリ側は marker 欠落の packaged 起動を拒否するため、channel 認識の
#   ずれた組は存在しない）

set -euo pipefail

# シンボリックリンクを解決して実体のディレクトリを取得
SOURCE="$0"
while [[ -L "${SOURCE}" ]]; do
  DIR="$(cd "$(dirname "${SOURCE}")" && pwd)"
  SOURCE="$(readlink "${SOURCE}")"
  [[ "${SOURCE}" != /* ]] && SOURCE="${DIR}/${SOURCE}"
done
SCRIPT_DIR="$(cd "$(dirname "${SOURCE}")" && pwd)"

CLI="${SCRIPT_DIR}/gozd-cli"
APP_RESOURCES="${SCRIPT_DIR}/.."
APP_CONTENTS="${APP_RESOURCES}/../.."
APP_BUNDLE="${APP_CONTENTS}/.."

# 空白・改行を除去して main（gozdEnv の trim）と channel 認識がずれないようにする
# （tr は内部空白まで消すため trim より広いが、marker 値は buildApp.ts が書く
# stable / local のみで空白を含まず、到達可能な入力では等価）
CHANNEL=""
[[ -f "${APP_RESOURCES}/channel" ]] && CHANNEL="$(tr -d '[:space:]' < "${APP_RESOURCES}/channel")"

TMPDIR_NORMALIZED="${TMPDIR:-/tmp}"
SOCKET_PATH="${GOZD_SOCKET_PATH:-${TMPDIR_NORMALIZED%/}/gozd-${CHANNEL:-stable}.sock}"

# Dock ピン / Spotlight が指す固定パス。mise 側の実体はバージョンごとにパスが変わるため、
# 固定パスへの実体 copy を起動対象にする（symlink は Spotlight に index されない）
INSTALL_APP="${HOME}/Applications/Gozd.app"

# mise 側 .app と固定パスの CFBundleVersion を比較し、差異があれば APFS clone（cp -Rc）で
# 複製してから mv で atomic に差し替える。アプリ稼働中の swap も安全（旧プロセスは開いた
# inode を掴んだまま動き続け、次回起動から新版になる。Homebrew cask の upgrade と同じ扱い）
sync_installed_app() {
  local src src_ver dest_ver tmp old
  src="$(cd "${APP_BUNDLE}" && pwd -P)"
  # wrapper 自身が固定パス側の実体なら同期不要（自分自身の差し替えを防ぐ）
  if [[ "${src}" == "$(cd "${INSTALL_APP}" 2>/dev/null && pwd -P)" ]]; then
    return 0
  fi
  src_ver="$(/usr/libexec/PlistBuddy -c 'Print :CFBundleVersion' "${src}/Contents/Info.plist")"
  # PlistBuddy はファイル不在時に "File Doesn't Exist" を stdout に出すため、存在ガードで
  # dest_ver を決定的にする（不在 = 空 = 不一致で同期に進む）
  dest_ver=""
  if [[ -f "${INSTALL_APP}/Contents/Info.plist" ]]; then
    dest_ver="$(/usr/libexec/PlistBuddy -c 'Print :CFBundleVersion' "${INSTALL_APP}/Contents/Info.plist")"
  fi
  if [[ "${src_ver}" == "${dest_ver}" ]]; then
    return 0
  fi
  mkdir -p "${HOME}/Applications"
  # 過去の失敗実行が残した作業ディレクトリ（PID 付き名）を回収する。trap は SIGKILL で
  # 走らず、PID 付き名は再実行と一致しないため、実行のたびに前回分を glob で掃除する。
  # cold start の並走時に他プロセスの .new.<pid> を消しうるが、消された側は set -e で
  # loud に落ち、成功側の atomic swap で固定パスは常に妥当な状態を保つため許容する
  rm -rf "${INSTALL_APP}".new.* "${INSTALL_APP}".old.*
  tmp="${INSTALL_APP}.new.$$"
  old="${INSTALL_APP}.old.$$"
  cp -Rc "${src}" "${tmp}"
  [[ -e "${INSTALL_APP}" ]] && mv "${INSTALL_APP}" "${old}"
  mv "${tmp}" "${INSTALL_APP}"
  rm -rf "${old}"
}

is_app_running() {
  [[ -S "${SOCKET_PATH}" ]] || return 1
  # ソケットファイルがあっても実際に接続できるか確認（残骸検出）
  if ! echo "" | nc -U "${SOCKET_PATH}" 2>/dev/null; then
    rm -f "${SOCKET_PATH}"
    return 1
  fi
  return 0
}

# hook / フラグ系はアプリ起動を要求しない
should_launch_app() {
  is_app_running && return 1
  [[ "${1:-}" == "hook" || "${1:-}" == -* ]] && return 1
  return 0
}

# mise の postinstall（'"$MISE_TOOL_INSTALL_PATH/bin/gozd" sync-app'）から呼ばれる同期
# エントリポイント。インストール直後に走るため、Dock / Spotlight しか使わないユーザーにも
# 更新が伝播する。cold start 同期は postinstall 未設定環境向けのバックアップ（docs/release.md）
if [[ "${1:-}" == "sync-app" ]]; then
  if [[ "${CHANNEL}" != "stable" ]]; then
    echo "gozd: sync-app is only for the stable channel (channel: ${CHANNEL:-unset})" >&2
    exit 1
  fi
  sync_installed_app
  exit 0
fi

if should_launch_app "$@"; then
  # cold start: CLI に launch request ファイルを書かせてからアプリを起動
  GOZD_COLD_START=1 GOZD_SOCKET_PATH="${SOCKET_PATH}" "${CLI}" "$@" || exit $?
  if [[ "${CHANNEL}" == "stable" ]]; then
    sync_installed_app
    open "${INSTALL_APP}"
  else
    open "${APP_BUNDLE}"
  fi
  exit $?
fi

# warm start: ソケット経由で送信（exec して exit code を継承）
exec env GOZD_SOCKET_PATH="${SOCKET_PATH}" "${CLI}" "$@"
