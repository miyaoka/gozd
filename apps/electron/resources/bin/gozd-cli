#!/usr/bin/env bash
# gozd-cli shim（packaged）。ELECTRON_RUN_AS_NODE=1 で同梱 Electron バイナリを Node と
# して使い dist/cli.cjs を実行する（codiff の bin/codiff-app と同じ手法。ユーザー環境に
# Node を要求しない）。dev 用 shim は apps/electron/bin/gozd-cli（node で実行）。

set -euo pipefail

SOURCE="$0"
while [[ -L "${SOURCE}" ]]; do
  DIR="$(cd "$(dirname "${SOURCE}")" && pwd)"
  SOURCE="$(readlink "${SOURCE}")"
  [[ "${SOURCE}" != /* ]] && SOURCE="${DIR}/${SOURCE}"
done
SCRIPT_DIR="$(cd "$(dirname "${SOURCE}")" && pwd)"

# SCRIPT_DIR = Contents/Resources/app/bin → ../../../MacOS/Gozd = Contents/MacOS/Gozd
# cli.cjs は asarUnpack で app.asar.unpacked/dist/ に展開される（ELECTRON_RUN_AS_NODE は
# asar 統合をバイパスするため asar 内の dist/cli.cjs は require から見えない）。
# SCRIPT_DIR(app/bin) → ../../app.asar.unpacked/dist/cli.cjs = Contents/Resources/app.asar.unpacked/dist/cli.cjs
exec env ELECTRON_RUN_AS_NODE=1 "${SCRIPT_DIR}/../../../MacOS/Gozd" "${SCRIPT_DIR}/../../app.asar.unpacked/dist/cli.cjs" "$@"
