{
  "name": "@gozd/electron",
  "version": "0.0.0",
  "private": true,
  "description": "Electron shell spike (issue #895): BrowserWindow + typed IPC + node-pty + xterm.js",
  "type": "module",
  "main": "dist/main.cjs",
  "scripts": {
    "build": "bun ./build.ts",
    "build:app": "bun ./ensureElectronDist.ts && pnpm --filter @gozd/renderer build && pnpm build && iconutil -c icns build/icon.iconset -o build/icon.icns && electron-builder --dir",
    "dev": "pnpm build && electron .",
    "start": "electron .",
    "spike": "pnpm build && GOZD_SPIKE_TEST=1 electron .",
    "test": "bun test",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@parcel/watcher": "2.5.6",
    "node-pty": "1.2.0-beta.14"
  },
  "devDependencies": {
    "electron-builder": "26.15.6",
    "@gozd/rpc": "workspace:*",
    "@gozd/shared": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "electron": "43.0.0",
    "esbuild": "0.28.1",
    "typescript": "catalog:"
  }
}
