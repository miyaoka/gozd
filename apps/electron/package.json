{
  "name": "@gozd/electron",
  "version": "0.1.0",
  "private": true,
  "description": "Gozd — Git Orchestrated Zone for Development. Electron main process for managing parallel AI agent development.",
  "author": "miyaoka",
  "type": "module",
  "main": "dist/main.cjs",
  "scripts": {
    "build": "bun ./build.ts",
    "build:app": "pnpm --filter @gozd/renderer build && pnpm build && iconutil -c icns build/icon.iconset -o build/icon.icns && bun ./buildApp.ts",
    "dev": "pnpm build && electron .",
    "start": "electron .",
    "spike": "pnpm build && GOZD_SPIKE_TEST=1 electron .",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --type-aware",
    "fix": "oxlint --type-aware --fix && oxfmt ."
  },
  "dependencies": {
    "@parcel/watcher": "2.6.0",
    "@vscode/ripgrep": "1.18.0",
    "node-pty": "1.2.0-beta.14"
  },
  "devDependencies": {
    "@gozd/rpc": "workspace:*",
    "@gozd/shared": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native": "catalog:",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "electron": "43.2.0",
    "electron-builder": "26.15.7",
    "esbuild": "0.28.1",
    "typescript": "catalog:"
  },
  "productName": "Gozd"
}
